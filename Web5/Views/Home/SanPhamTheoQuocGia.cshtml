@{
    ViewData["Title"] = "SanPhamTheoLoai";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using X.PagedList.Mvc.Core;
@model X.PagedList.IPagedList<Web5.Models.TDanhMucSp>;
@foreach (var sp in Model)
{
    <div class="col-lg-3 col-md-4 col-sm-6 mix vegetables fastfood">
        <div class="featured__item">
            <div class="featured__item__pic set-bg" data-setbg=@Url.Content("~/ImagesWebBanVali/" + sp.AnhDaiDien) style="background-image: url(&quot;img/featured/feature-2.jpg&quot;);">
                <ul class="featured__item__pic__hover">
                    <li><a href="#"><i class="fa fa-heart"></i></a></li>
                    <li><a href="#"><i class="fa fa-retweet"></i></a></li>
                    <li><a href="#"><i class="fa fa-shopping-cart"></i></a></li>
                </ul>
            </div>
            <div class="featured__item__text">
                <h6><a asp-controller="Home" asp-action="ChiTietSanPham" asp-route-maSp="@sp.MaSp" asp-action="SanPhamTheoQuocGia"> @sp.TenSp</a></h6>
                <h5>@sp.GiaLonNhat</h5>
            </div>
        </div>
    </div>
}
<div class="product__pagination">


    @Html.PagedListPager(Model, page => Url.Action("Index ", new { page = page, maNuoc  = ViewBag.maNuoc  }))

</div>

